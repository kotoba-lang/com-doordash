// Doordash clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace doordash {

    entity Order {
        id: string @unique
        customerId: string
        merchantId: string
        total: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Courier {
        id: string @unique
        name: string
        vehicle: string
        lat: float
        lon: float
        online: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Delivery {
        id: string @unique
        orderId: string
        courierId: string
        status: string
        etaMin: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Merchant {
        id: string @unique
        name: string
        cuisine: string
        lat: float
        lon: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Route {
        id: string @unique
        deliveryId: string
        distanceKm: float
        durationMin: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Tracking {
        id: string @unique
        deliveryId: string
        lat: float
        lon: float
        recordedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
